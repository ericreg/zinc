fn main() {
    scores = dict()
    scores["a"] = 1
    scores["b"] = 2

    key_count = 0
    for key in scores.keys() {
        key_count = key_count + 1
    }

    value_total = 0
    for value in scores.values() {
        value_total = value_total + value
    }

    item_total = 0
    item_count = 0
    for key, value in scores.items() {
        item_total = item_total + value
        item_count = item_count + 1
    }

    print("{key_count}")
    print("{value_total}")
    print("{item_total}")
    print("{item_count}")
}
