fn main() {
    for value in 0..3 {
        print("{value}")
    }

    for value in 1..=3 {
        print("{value}")
    }

    empty_count = 0
    for value in 0..0 {
        empty_count = empty_count + 1
    }
    print("{empty_count}")

    count = 0
    last = -1
    for value in 0..300 {
        count = count + 1
        last = value
    }
    print("{count}")
    print("{last}")
}
