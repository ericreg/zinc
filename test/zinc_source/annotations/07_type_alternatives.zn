fn keep_specific(x: i32 | f32) {
    return x
}

fn keep_numeric(x: numeric) {
    return x
}

#[x in numeric]
fn keep_numeric_attr(x) {
    return x
}

struct Measure {
    value: i32 | f32
}

fn main() {
    whole: i32 = 4
    ratio: f32 = 1.5

    whole_measure = Measure { value: whole }
    ratio_measure = Measure { value: ratio }

    print(keep_specific(whole))
    print(keep_specific(ratio))
    print(keep_numeric(9))
    print(keep_numeric_attr(10))
    print(whole_measure.value)
    print(ratio_measure.value)
}
