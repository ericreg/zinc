struct Point {
    x: i64
    y: i64

    fn operator==(left, right) -> bool {
        return left.x == right.x && left.y == right.y
    }

    fn operator+(rhs) -> Self {
        return Point { x: self.x + rhs.x y: self.y + rhs.y }
    }

    fn operator[](idx: i64) -> i64 {
        if idx == 0 {
            return self.x
        }
        return self.y
    }

    fn operator$$(left, right) -> Self {
        return Point { x: left.x + right.y y: left.y + right.x }
    }
}

struct Offset {
    value: i64

    fn operator+(left: Self, amount: i64) -> Self {
        return Offset { value: left.value + amount }
    }

    fn operator-() -> Self {
        return Offset { value: 0 - self.value }
    }

    fn operator..(left, right) -> Self {
        return Offset { value: right.value - left.value }
    }
}

struct Bag {
    value: i64

    fn operator in(candidate: i64) -> bool {
        return candidate == self.value
    }
}

fn main() {
    a = Point { x: 1 y: 2 }
    b = Point { x: 3 y: 4 }
    c = a + b
    print(c.x)

    d = Point { x: 5 y: 6 }
    e = Point { x: 7 y: 8 }
    d += e
    print(d.y)

    f = Point { x: 1 y: 2 }
    print(f[0])

    g = Point { x: 1 y: 2 }
    h = Point { x: 1 y: 9 }
    i = g $$ h
    print(i.x)

    j = Point { x: 1 y: 2 }
    k = Point { x: 1 y: 2 }
    print(j == k)

    o = Offset { value: 10 }
    p = o + 5
    print(p.value)

    q = -p
    print(q.value)

    r = Offset { value: 2 }
    s = Offset { value: 9 }
    span = r .. s
    print(span.value)

    bag = Bag { value: 42 }
    print(42 in bag)
}
