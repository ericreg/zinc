fn main() {
    a, b = (2, 3)
    print("{a}")
    print("{b}")

    (name, score) = ("ada", 9)
    print("{name}")
    print("{score}")

    x, y, z = 1
    print("{x} {y} {z}")
    x = "cat"
    y = 3.14
    z = 3
    print("{x} {y} {z}")

    fx, fy, fz: f32 = 1
    print("{fx} {fy} {fz}")

    value, label, item = (3.14, "cat", struct { id: 123456 })
    print("{value}")
    print("{label}")
    print("{item.id}")

    nested_left, nested_pair = (1, (2, 3))
    nested_a, nested_b = nested_pair
    print("{nested_left} {nested_a} {nested_b}")

    (single,) = (99,)
    print("{single}")

    typed_a, typed_b: f32 = (1, 2)
    print("{typed_a} {typed_b}")

    sx, sy = "dog"
    print("{sx} {sy}")
    sx = "cat"
    sy = "bird"
    print("{sx} {sy}")

    p1, p2 = struct { id: 7 }
    print("{p1.id} {p2.id}")

    rx: f32 = 0
    ry: f32 = 0
    rx, ry = 2
    print("{rx} {ry}")

    first, second = (10, 20)
    first, second = (second, first)
    print("{first} {second}")
}
