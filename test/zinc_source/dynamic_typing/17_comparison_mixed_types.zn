// Test: Comparison operators with mixed types
// Expected: Valid for same types, undefined for mixed

fn main() {
    // Same type comparisons - all valid

    // Integer comparisons
    a = 1 == 1
    print("1 == 1: {a}")

    b = 1 != 2
    print("1 != 2: {b}")

    c = 1 < 2
    print("1 < 2: {c}")

    d = 2 > 1
    print("2 > 1: {d}")

    e = 1 <= 1
    print("1 <= 1: {e}")

    f = 2 >= 1
    print("2 >= 1: {f}")

    // Float comparisons
    g = 1.0 == 1.0
    print("1.0 == 1.0: {g}")

    h = 1.5 > 1.0
    print("1.5 > 1.0: {h}")

    i = 0.5 < 1.0
    print("0.5 < 1.0: {i}")

    // Boolean comparisons
    j = true == true
    print("true == true: {j}")

    k = true != false
    print("true != false: {k}")

    // String comparisons
    l = "a" == "a"
    print("a == a: {l}")

    m = "a" != "b"
    print("a != b: {m}")

    // Mixed type comparisons - potentially undefined
    // Uncomment to test:
    // mixed1 = 1 == 1.0
    // print("1 == 1.0: {mixed1}")

    // mixed2 = "1" == 1
    // print("1 string == 1 int: {mixed2}")

    // Comparison result in expression
    n = (5 > 3) && (2 < 4)
    print("(5 > 3) && (2 < 4): {n}")

    print("test complete")
}
