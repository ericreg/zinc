// Test: Arrays, tuples, and channels can carry anonymous struct values.

fn main() {
    items = [
        struct {
            id: 1
            name: "one"
        },
        struct {
            id: 2
            name: "two"
        },
    ]

    pair = (
        struct {
            id: 3
            name: "three"
        },
        struct {
            ok: true
        },
    )

    first, status = pair

    jobs = chan()
    jobs <- struct {
        id: 4
        name: "four"
    }
    received = <-jobs

    print(items[0].id)
    print(items[1].name)
    print(first.name)
    print(status.ok)
    print(received.id)
    print(received.name)
}
