// Test: Basic struct fields with explicit types and default values

struct Point {
    x: i32
    y: i32
}

struct Counter {
    count: 0      // default value, type inferred as integer
    step: 1       // default value
    name: string  // explicit type, zero-initialized to ""
}

fn main() {
    // Create Point with explicit field values
    p = Point { x: 10, y: 20 }
    print(p.x)
    print(p.y)

    // Create Counter - uses default values for count and step
    c = Counter { name: "my_counter" }
    print(c.count)
    print(c.step)
}


struct File {
    path: string
}

struct Message {
    text: string
    timestamp: i64
}

struct Item [
        File,
        Message,
    ] {

    owner_id: i32

    fn print() {
        print("Rectangle: {self.path}")
        print("owner_id: {self.owner_id}")
        print("timestamp: {self.timestamp}")
    }
}
