{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Zinc",
  "scopeName": "source.zinc",
  "fileTypes": ["zn"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#attributes" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#imports" },
    { "include": "#struct_compositions" },
    { "include": "#anonymous_structs" },
    { "include": "#declarations" },
    { "include": "#types" },
    { "include": "#builtin_types" },
    { "include": "#named_arguments" },
    { "include": "#module_paths" },
    { "include": "#struct_instantiations" },
    { "include": "#constants" },
    { "include": "#self" },
    { "include": "#patterns_zinc" },
    { "include": "#out_assignments" },
    { "include": "#keywords" },
    { "include": "#result_option_constructors" },
    { "include": "#builtins" },
    { "include": "#function_calls" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "attributes": {
      "patterns": [
        {
          "name": "meta.attribute.zinc",
          "begin": "#\\[",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.attribute.begin.zinc" }
          },
          "end": "\\]",
          "endCaptures": {
            "0": { "name": "punctuation.definition.attribute.end.zinc" }
          },
          "patterns": [
            { "include": "#comments" },
            { "include": "#strings" },
            { "include": "#numbers" },
            { "include": "#types" },
            { "include": "#builtin_types" },
            { "include": "#keywords" },
            { "include": "#result_option_constructors" },
            { "include": "#builtins" },
            { "include": "#operators" },
            { "include": "#punctuation" },
            { "include": "#identifiers" }
          ]
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.zinc",
          "match": "//.*$"
        },
        {
          "name": "comment.block.zinc",
          "begin": "/\\*",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.comment.begin.zinc" }
          },
          "end": "\\*/",
          "endCaptures": {
            "0": { "name": "punctuation.definition.comment.end.zinc" }
          }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.other.raw.zinc",
          "begin": "`",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.zinc" }
          },
          "end": "(?<!`)`(?!`)",
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.zinc" }
          },
          "patterns": [
            {
              "name": "constant.character.escape.zinc",
              "match": "``"
            }
          ]
        },
        {
          "name": "string.quoted.double.zinc",
          "begin": "\"",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.zinc" }
          },
          "end": "\"",
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.zinc" }
          },
          "patterns": [
            { "include": "#escape_sequences" },
            { "include": "#interpolation" }
          ]
        },
        {
          "name": "string.quoted.single.zinc",
          "begin": "'",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.zinc" }
          },
          "end": "'",
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.zinc" }
          },
          "patterns": [
            { "include": "#escape_sequences" },
            { "include": "#interpolation" }
          ]
        }
      ]
    },
    "escape_sequences": {
      "name": "constant.character.escape.zinc",
      "match": "\\\\([btnfr\"'\\\\]|u[0-9a-fA-F]{4})"
    },
    "interpolation": {
      "name": "meta.interpolation.zinc",
      "begin": "\\{",
      "beginCaptures": {
        "0": { "name": "punctuation.section.interpolation.begin.zinc" }
      },
      "end": "\\}",
      "endCaptures": {
        "0": { "name": "punctuation.section.interpolation.end.zinc" }
      },
      "patterns": [
        { "include": "#numbers" },
        { "include": "#constants" },
        { "include": "#self" },
        { "include": "#builtin_types" },
        { "include": "#keywords" },
        { "include": "#result_option_constructors" },
        { "include": "#builtins" },
        { "include": "#named_arguments" },
        { "include": "#function_calls" },
        { "include": "#operators" },
        { "include": "#punctuation" },
        { "include": "#identifiers" }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.zinc",
          "match": "\\b(?:[0-9]+\\.[0-9]+(?:[eE][+-]?[0-9]+)?|[0-9]+[eE][+-]?[0-9]+)\\b"
        },
        {
          "name": "constant.numeric.hex.zinc",
          "match": "\\b0x[0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.octal.zinc",
          "match": "\\b0o[0-7]+\\b"
        },
        {
          "name": "constant.numeric.binary.zinc",
          "match": "\\b0b[01]+\\b"
        },
        {
          "name": "constant.numeric.integer.zinc",
          "match": "\\b(?:0|[1-9][0-9]*)\\b"
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "name": "meta.function.zinc",
          "match": "\\b(fn|async)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "keyword.declaration.function.zinc" },
            "2": { "name": "entity.name.function.zinc" }
          }
        },
        {
          "name": "meta.struct.zinc",
          "match": "\\b(struct)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": { "name": "keyword.declaration.struct.zinc" },
            "2": { "name": "entity.name.type.struct.zinc" }
          }
        },
        {
          "name": "meta.enum.zinc",
          "match": "\\b(enum)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": { "name": "keyword.declaration.enum.zinc" },
            "2": { "name": "entity.name.type.enum.zinc" }
          }
        },
        {
          "name": "meta.constant.zinc",
          "match": "\\b(const)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": { "name": "storage.modifier.const.zinc" },
            "2": { "name": "variable.other.constant.zinc" }
          }
        }
      ]
    },
    "struct_compositions": {
      "patterns": [
        {
          "name": "meta.struct.composition.zinc",
          "begin": "\\b(struct)\\s+([A-Za-z_][A-Za-z0-9_]*)(\\s*)(\\[)",
          "beginCaptures": {
            "1": { "name": "keyword.declaration.struct.zinc" },
            "2": { "name": "entity.name.type.struct.zinc" },
            "4": { "name": "punctuation.section.brackets.begin.zinc" }
          },
          "end": "\\]",
          "endCaptures": {
            "0": { "name": "punctuation.section.brackets.end.zinc" }
          },
          "patterns": [
            { "include": "#comments" },
            { "include": "#composition_type_paths" },
            {
              "name": "punctuation.separator.composition.orthogonal.zinc",
              "match": "\\|"
            },
            {
              "name": "punctuation.separator.comma.zinc",
              "match": ","
            }
          ]
        }
      ]
    },
    "anonymous_structs": {
      "patterns": [
        {
          "name": "meta.struct.anonymous.zinc",
          "begin": "\\b(struct)(\\s*)(\\{)",
          "beginCaptures": {
            "1": { "name": "keyword.declaration.struct.zinc" },
            "3": { "name": "punctuation.section.block.begin.zinc" }
          },
          "end": "\\}",
          "endCaptures": {
            "0": { "name": "punctuation.section.block.end.zinc" }
          },
          "patterns": [
            { "include": "#comments" },
            { "include": "#strings" },
            { "include": "#numbers" },
            { "include": "#types" },
            { "include": "#keywords" },
            { "include": "#operators" },
            { "include": "#punctuation" }
          ]
        }
      ]
    },
    "composition_type_paths": {
      "patterns": [
        {
          "name": "meta.path.composed-struct.zinc",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)(\\.)((?:[A-Za-z_][A-Za-z0-9_]*)(?:\\.[A-Za-z_][A-Za-z0-9_]*)*)\\b",
          "captures": {
            "1": { "name": "entity.name.namespace.zinc" },
            "2": { "name": "punctuation.accessor.zinc" },
            "3": { "name": "entity.name.type.struct.zinc" }
          }
        },
        {
          "name": "entity.name.type.struct.zinc",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "imports": {
      "patterns": [
        {
          "name": "meta.import.zinc",
          "begin": "^(\\s*)(import)\\b",
          "beginCaptures": {
            "2": { "name": "keyword.control.import.zinc" }
          },
          "end": "$",
          "patterns": [
            { "include": "#comments" },
            { "include": "#import_path" },
            { "include": "#import_alias" },
            { "include": "#import_list" }
          ]
        }
      ]
    },
    "import_path": {
      "patterns": [
        {
          "name": "meta.import.path.zinc",
          "begin": "\\G\\s+",
          "end": "(?=\\s*(?:\\bas\\b|\\[|$))",
          "patterns": [
            {
              "name": "entity.name.namespace.zinc",
              "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
            },
            {
              "name": "punctuation.separator.path.zinc",
              "match": "/"
            }
          ]
        }
      ]
    },
    "import_alias": {
      "patterns": [
        {
          "name": "meta.import.alias.zinc",
          "match": "\\b(as)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": { "name": "keyword.control.import.zinc" },
            "2": { "name": "entity.name.namespace.alias.zinc" }
          }
        }
      ]
    },
    "import_list": {
      "patterns": [
        {
          "name": "meta.import.list.zinc",
          "begin": "\\[",
          "beginCaptures": {
            "0": { "name": "punctuation.section.brackets.begin.zinc" }
          },
          "end": "\\]",
          "endCaptures": {
            "0": { "name": "punctuation.section.brackets.end.zinc" }
          },
          "patterns": [
            {
              "name": "variable.other.constant.zinc",
              "match": "\\b[A-Z][A-Z0-9_]*\\b"
            },
            {
              "name": "entity.name.type.zinc",
              "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
            },
            {
              "name": "entity.name.function.zinc",
              "match": "\\b[a-z_][A-Za-z0-9_]*\\b"
            },
            {
              "name": "punctuation.separator.comma.zinc",
              "match": ","
            }
          ]
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "meta.type.annotation.parameter.alternative.zinc",
          "begin": "(?<=[\\(,])\\s*([A-Za-z_][A-Za-z0-9_]*)(\\s*:\\s*)(?=[^,\\)\\n]*\\|)",
          "beginCaptures": {
            "1": { "name": "variable.parameter.zinc" },
            "2": { "name": "punctuation.separator.type.zinc" }
          },
          "end": "(?=\\s*(?:=|[,\\)]))",
          "patterns": [
            { "include": "#builtin_types" },
            { "include": "#type_atoms" },
            { "include": "#type_alternative_separator" }
          ]
        },
        {
          "name": "meta.type.annotation.field.alternative.zinc",
          "begin": "^\\s*(?:(const)\\s+)?([A-Za-z_][A-Za-z0-9_]*)(\\s*:\\s*)(?=[^\\n]*\\|)",
          "beginCaptures": {
            "1": { "name": "storage.modifier.const.zinc" },
            "2": { "name": "variable.other.member.zinc" },
            "3": { "name": "punctuation.separator.type.zinc" }
          },
          "end": "(?=\\s*(?://.*)?$)",
          "patterns": [
            { "include": "#builtin_types" },
            { "include": "#type_atoms" },
            { "include": "#type_alternative_separator" }
          ]
        },
        {
          "name": "meta.type.annotation.parameter.zinc",
          "match": "(?<=[\\(,])\\s*([A-Za-z_][A-Za-z0-9_]*)(\\s*:\\s*)(\\[[^\\n\\]]+\\]|\\([^\\n\\)]*\\)\\s*->\\s*[^,\\)\\n]+|\\([^\\n\\)]+\\)|[A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)*(?:\\s*<[^\\n{};=]+>)?)(?=\\s*(?:=|[,\\)]))",
          "captures": {
            "1": { "name": "variable.parameter.zinc" },
            "2": { "name": "punctuation.separator.type.zinc" },
            "3": { "name": "entity.name.type.zinc" }
          }
        },
        {
          "name": "meta.type.annotation.field.zinc",
          "match": "^\\s*(?:(const)\\s+)?((?:[A-Za-z_][A-Za-z0-9_]*\\s*,\\s*)*[A-Za-z_][A-Za-z0-9_]*)(\\s*:\\s*)(\\[[^\\n\\]]+\\]|\\([^\\n\\)]*\\)\\s*->\\s*[^,\\)\\n]+|\\([^\\n\\)]+\\)|(?:i8|i16|i32|i64|i128|u8|u16|u32|u64|u128|f8|f16|f32|f64|f128|string|bool|Context|numeric|infer)\\b|[A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)*(?:\\s*<[^\\n{};=]+>)?)(?=\\s*(?:=|(?://.*)?$))",
          "captures": {
            "1": { "name": "storage.modifier.const.zinc" },
            "2": { "name": "variable.other.member.zinc" },
            "3": { "name": "punctuation.separator.type.zinc" },
            "4": { "name": "entity.name.type.zinc" }
          }
        }
      ]
    },
    "type_atoms": {
      "patterns": [
        {
          "name": "entity.name.type.zinc",
          "match": "\\[[^\\n\\]]+\\]|\\([^\\n\\)]*\\)\\s*->\\s*[^|,\\)\\n]+|\\([^\\n\\)]+\\)|\\b[A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)*(?:\\s*<[^\\n{};=|]+>)?\\b"
        }
      ]
    },
    "type_alternative_separator": {
      "name": "punctuation.separator.type-alternative.zinc",
      "match": "\\|"
    },
    "builtin_types": {
      "patterns": [
        {
          "name": "support.type.builtin.zinc",
          "match": "\\b(?:Context|Result|Option|numeric)\\b"
        }
      ]
    },
    "module_paths": {
      "name": "entity.name.namespace.zinc",
      "match": "\\b[A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)+\\b"
    },
    "struct_instantiations": {
      "name": "entity.name.type.struct.zinc",
      "match": "\\b(?:[A-Z][A-Za-z0-9_]*|[A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)+)\\s*(?=\\{)"
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.zinc",
          "match": "\\b(?:true|false)\\b"
        },
        {
          "name": "constant.language.nil.zinc",
          "match": "\\bnil\\b"
        },
        {
          "name": "constant.language.option.none.zinc",
          "match": "\\bNone\\b"
        }
      ]
    },
    "self": {
      "name": "variable.language.self.zinc",
      "match": "\\bself\\b"
    },
    "patterns_zinc": {
      "patterns": [
        {
          "name": "constant.other.wildcard.zinc",
          "match": "\\b_\\b"
        }
      ]
    },
    "out_assignments": {
      "patterns": [
        {
          "name": "keyword.control.zinc",
          "match": "\\bout\\b(?=\\s+[A-Za-z_][A-Za-z0-9_]*\\s*(?:(?:\\*\\*)|[+\\-*/%])?=)"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.zinc",
          "match": "\\b(?:if|else|for|in|while|loop|match|return|break|continue|try|fail)\\b"
        },
        {
          "name": "keyword.other.concurrency.zinc",
          "match": "\\b(?:spawn|select|case|default|await)\\b"
        },
        {
          "name": "keyword.operator.word.zinc",
          "match": "\\b(?:and|or|not)\\b"
        },
        {
          "name": "keyword.declaration.zinc",
          "match": "\\b(?:fn|async|struct|enum|const|import|as)\\b"
        },
        {
          "name": "storage.type.special.zinc",
          "match": "\\b(?:infer)\\b"
        }
      ]
    },
    "result_option_constructors": {
      "patterns": [
        {
          "name": "support.function.constructor.zinc",
          "match": "\\b(?:Ok|Err|Some)\\s*(?=\\()"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.builtin.zinc",
          "match": "\\b(?:print|chan|close|dict|set|sort_dict|sort_set|meta|type|line|has_component|implements)\\s*(?=\\()"
        }
      ]
    },
    "named_arguments": {
      "patterns": [
        {
          "name": "meta.argument.named.zinc",
          "match": "(?<=[\\(,])\\s*([A-Za-z_][A-Za-z0-9_]*)(\\s*=)(?=\\s*[^=])",
          "captures": {
            "1": { "name": "variable.parameter.argument.zinc" },
            "2": { "name": "keyword.operator.assignment.zinc" }
          }
        }
      ]
    },
    "function_calls": {
      "name": "meta.function-call.zinc",
      "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
      "captures": {
        "1": { "name": "entity.name.function.zinc" }
      }
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.channel.zinc",
          "match": "<-"
        },
        {
          "name": "keyword.operator.range.zinc",
          "match": "\\.\\.(?:=)?"
        },
        {
          "name": "keyword.operator.arrow.zinc",
          "match": "=>|->"
        },
        {
          "name": "keyword.operator.comparison.zinc",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.zinc",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.assignment.zinc",
          "match": "(?<![=!<>])=(?!=)"
        },
        {
          "name": "keyword.operator.arithmetic.zinc",
          "match": "[+\\-*/%]"
        },
        {
          "name": "punctuation.accessor.zinc",
          "match": "\\."
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.terminator.statement.zinc",
          "match": ";"
        },
        {
          "name": "punctuation.separator.comma.zinc",
          "match": ","
        },
        {
          "name": "punctuation.separator.key-value.zinc",
          "match": ":"
        },
        {
          "name": "punctuation.section.block.zinc",
          "match": "[{}]"
        },
        {
          "name": "punctuation.section.brackets.zinc",
          "match": "[\\[\\]]"
        },
        {
          "name": "punctuation.section.parens.zinc",
          "match": "[()]"
        },
        {
          "name": "meta.lambda.zinc",
          "match": "\\bfn(?=\\s*\\()"
        }
      ]
    },
    "identifiers": {
      "name": "variable.other.zinc",
      "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
    }
  }
}
